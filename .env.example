# Copy this file to .env and fill in the values you want locally.

# Scoped LangSmith tracing. LangQuest traces AI/RAG work explicitly instead of
# turning every Python call into a global trace.
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=langQuest
# LANGSMITH_API_KEY=your-langsmith-api-key

# Model providers. Add at least one key for AI-driven play.
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
